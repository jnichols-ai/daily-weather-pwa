# monday.com API token (Admin > API in your monday account). Needs board read/write scopes.
MONDAY_API_TOKEN=

# Board IDs created for this project (Service workspace)
MONDAY_HISTORY_BOARD_ID=18419232698
MONDAY_CURRENT_BOARD_ID=18419232702

# Shared secret to protect the cron endpoint from being called by anyone but Vercel Cron.
# Set the same value in Vercel's Environment Variables.
CRON_SECRET=change-me

# Required by NWS API per their usage policy: identify your app with a contact.
NWS_USER_AGENT=daily-weather-pwa (justinmnichols@gmail.com)
